  "item": [
    {
      "name": "Add new employee",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();",
              "pm.environment.set(\"employee_id\", response.id);",
              "console.log(\"Employee ID set:\", response.id)",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 2 seconds\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Employee object contains required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 0) {",
              "        pm.expect(jsonData[0]).to.have.property(\"id\");",
              "        pm.expect(jsonData[0]).to.have.property(\"firstName\");",
              "        pm.expect(jsonData[0]).to.have.property(\"lastName\");",
              "        pm.expect(jsonData[0]).to.have.property(\"dependants\");",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "password",
              "value": "b@Qc|({91RIA",
              "type": "string"
            },
            {
              "key": "username",
              "value": "TestUser519",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic VGVzdFVzZXI1MTk6YkBRY3woezkxUklB",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"{{$randomFirstName}}\",\n  \"lastName\": \"{{$randomLastName}}\",\n  \"dependants\": 2,\n  \"salary\": 52000\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/Prod/api/Employees",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Prod",
            "api",
            "Employees"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List of Employees",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Get the expected employee ID",
              "const expectedId = pm.environment.get(\"employee_id\");",
              "console.log(\"Expected Employee ID:\", expectedId);",
              "",
              "const usersList = pm.response.json();",
              "",
              "const employee = usersList.find(u => u.id === expectedId);",
              "",
              "pm.test(\"Employee fields exist\", () => {",
              "        pm.expect(employee).to.have.property(\"id\");",
              "        pm.expect(employee).to.have.property(\"firstName\");",
              "        pm.expect(employee).to.have.property(\"lastName\");",
              "        pm.expect(employee).to.have.property(\"dependants\");",
              "        pm.expect(employee).to.have.property(\"salary\");",
              "        pm.expect(employee).to.have.property(\"gross\");",
              "        pm.expect(employee).to.have.property(\"benefitsCost\");",
              "        pm.expect(employee).to.have.property(\"net\");",
              "    });",
              "",
              "pm.test(\"Net pay equals gross minus benefits cost\", () => {",
              "        const calculatedNet = employee.gross - employee.benefitsCost;",
              "        pm.expect(employee.net).to.be.closeTo(calculatedNet, 0.01);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
